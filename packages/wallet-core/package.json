{
  "name": "@acorus/wallet-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @acorus/shared build",
    "build": "tsup src/index.ts --format esm --clean",
    "lint": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm --filter @acorus/shared build",
    "test": "vitest run"
  },
  "dependencies": {
    "@acorus/shared": "workspace:*",
    "bip39": "^3.1.0",
    "viem": "^2.49.0",
    "zod": "^4.4.3"
  }
}
