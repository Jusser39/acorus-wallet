{
  "name": "@acorus/wallet-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @acorus/shared build",
    "build": "tsup src/index.ts --format esm --clean",
    "lint": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm --filter @acorus/shared build",
    "test": "vitest run"
  },
  "dependencies": {
    "@acorus/shared": "workspace:*",
    "@noble/curves": "^1.9.1",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.6",
    "@scure/bip32": "^1.7.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "bip39": "^3.1.0",
    "ed25519-hd-key": "^2.0.0",
    "tweetnacl": "^1.0.3",
    "viem": "^2.49.0",
    "zod": "^4.4.3"
  }
}
