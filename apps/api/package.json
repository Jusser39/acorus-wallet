{
  "name": "@acorus/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prebuild": "pnpm --filter @acorus/shared build && pnpm --filter @acorus/wallet-core build",
    "build": "tsup src/server.ts src/app.ts --format esm --clean",
    "start:prod": "node dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm --filter @acorus/shared build && pnpm --filter @acorus/wallet-core build",
    "test": "vitest run",
    "prisma": "prisma --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@acorus/shared": "workspace:*",
    "@acorus/wallet-core": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.16.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "prisma": "6.16.2"
  }
}
