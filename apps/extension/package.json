{
  "name": "@acorus/extension",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @acorus/wallet-core build",
    "build": "tsup --config tsup.config.ts && tailwindcss -i src/ui/index.css -o dist/index.css && node ./scripts/postbuild.mjs",
    "lint": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm --filter @acorus/wallet-core build",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@acorus/shared": "workspace:*",
    "@acorus/wallet-core": "workspace:*",
    "@walletconnect/core": "^2.23.9",
    "@walletconnect/web3wallet": "^1.16.1",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
