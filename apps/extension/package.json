{
  "name": "@acorus/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @acorus/shared build",
    "build": "tsup --config tsup.config.ts && node ./scripts/postbuild.mjs",
